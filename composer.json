{
  "name": "maatify/crypto",
  "description": "High-level cryptographic primitives and security utilities for Maatify systems including password hashing, reversible encryption, HKDF key derivation, and key rotation.",
  "type": "library",
  "license": "MIT",

  "require": {
    "php": "^8.2",
    "ext-openssl": "*",
    "ext-sodium": "*"
  },

  "require-dev": {
    "php-di/php-di": "^7.0",
    "slim/psr7": "^1.8",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.0"
  },

  "autoload": {
    "psr-4": {
      "Maatify\\Crypto\\": "src/"
    }
  },

  "autoload-dev": {
    "psr-4": {
      "Maatify\\Crypto\\Tests\\": "tests/"
    }
  },

  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.2.0"
    }
  },

  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src tests --level=max",
    "format": "php-cs-fixer fix"
  },

  "minimum-stability": "stable",
  "prefer-stable": true,

  "keywords": [
    "crypto",
    "encryption",
    "security",
    "hkdf",
    "password",
    "argon2",
    "key-rotation",
    "maatify"
  ],

  "authors": [
    {
      "name": "Maatify",
      "email": "support@maatify.com"
    }
  ],

  "support": {
    "issues": "https://github.com/maatify/crypto/issues",
    "source": "https://github.com/maatify/crypto"
  }
}